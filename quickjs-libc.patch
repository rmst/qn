+/* Source transform hook for module loading.
+   Set from JS via std._setSourceTransform(fn).
+   fn(source, filename) is called for every module load;
+   it should return the (possibly transformed) source. */
+static int source_transform_set = 0;
+static JSValue source_transform_fn;
+static JSContext *source_transform_ctx = NULL;
+
+/* Apply source transform hook to loaded source code.
+   Takes ownership of buf; returns (possibly new) buffer.
+   On error, frees buf and returns NULL. */
+uint8_t *js_std_apply_source_transform(JSContext *ctx, uint8_t *buf,
+                                        size_t buf_len, const char *filename,
+                                        size_t *out_len) {
+    *out_len = buf_len;
+    if (!source_transform_set)
+        return buf;
+    JSValue args[2];
+    args[0] = JS_NewStringLen(ctx, (char *)buf, buf_len);
+    args[1] = JS_NewString(ctx, filename);
+    js_free(ctx, buf);
+    JSValue result = JS_Call(ctx, source_transform_fn, JS_UNDEFINED, 2, args);
+    JS_FreeValue(ctx, args[0]);
+    JS_FreeValue(ctx, args[1]);
+    if (JS_IsException(result))
+        return NULL;
+    size_t new_len;
+    const char *str = JS_ToCStringLen(ctx, &new_len, result);
+    JS_FreeValue(ctx, result);
+    if (!str)
+        return NULL;
+    uint8_t *new_buf = js_malloc(ctx, new_len + 1);
+    if (!new_buf) {
+        JS_FreeCString(ctx, str);
+        return NULL;
+    }
+    memcpy(new_buf, str, new_len + 1);
+    *out_len = new_len;
+    JS_FreeCString(ctx, str);
+    return new_buf;
+}
+
+/* Set the source transform hook from C.
+   fn must be a JS function; ownership is shared (DupValue). */
+void js_std_set_source_transform_fn(JSContext *ctx, JSValue fn) {
+    if (source_transform_set && source_transform_ctx) {
+        JS_FreeValue(source_transform_ctx, source_transform_fn);
+    }
+    source_transform_fn = JS_DupValue(ctx, fn);
+    source_transform_ctx = ctx;
+    source_transform_set = 1;
+}
