[submodule "quickjs"]
	path = quickjs
	url = https://github.com/bellard/quickjs.git
	ignore = dirty
[submodule "vendor/bearssl"]
	path = vendor/bearssl
	url = https://github.com/nickray/bearssl
[submodule "vendor/lwip"]
	path = vendor/lwip
	url = https://github.com/lwip-tcpip/lwip.git
[submodule "vendor/wireguard-lwip"]
	path = vendor/wireguard-lwip
	url = https://github.com/smartalock/wireguard-lwip.git
