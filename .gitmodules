[submodule "quickjs"]
	path = quickjs
	url = https://github.com/bellard/quickjs.git
	ignore = dirty
[submodule "node/node/tls/bearssl"]
	path = vendor/bearssl
	url = https://github.com/nickray/bearssl
[submodule "vendor/libuv"]
	path = vendor/libuv
	url = https://github.com/libuv/libuv.git
[submodule "vendor/sucrase-js"]
	path = vendor/sucrase-js
	url = https://github.com/rmst/sucrase-js.git
	ignore = dirty
