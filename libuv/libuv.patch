+static void qn_timer_cb(uv_timer_t *handle)
+{
+    JSOSTimer *th = handle->data;
+    JSContext *ctx = (JSContext *)handle->loop->data;
+    JSRuntime *rt = JS_GetRuntime(ctx);
+    JSValue func;
+    func = th->func;
+    th->func = JS_UNDEFINED;
+    free_timer(rt, th);
+    call_handler(ctx, func);
+    JS_FreeValue(ctx, func);
+}
