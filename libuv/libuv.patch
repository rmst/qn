+static void qn_poll_rw_cb(uv_poll_t *handle, int status, int events)
+{
+    JSOSRWHandler *rh = handle->data;
+    JSContext *ctx = rh->ctx;
+    if (status < 0) return;
+    if ((events & UV_READABLE) && !JS_IsNull(rh->rw_func[0]))
+        call_handler(ctx, rh->rw_func[0]);
+    if ((events & UV_WRITABLE) && !JS_IsNull(rh->rw_func[1]))
+        call_handler(ctx, rh->rw_func[1]);
+}
+
+static void update_uv_poll(JSContext *ctx, JSThreadState *ts, JSOSRWHandler *rh)
+{
+    int events = 0;
+    if (!JS_IsNull(rh->rw_func[0])) events |= UV_READABLE;
+    if (!JS_IsNull(rh->rw_func[1])) events |= UV_WRITABLE;
+    if (events == 0) {
+        if (rh->uv_handle) {
+            uv_poll_stop(rh->uv_handle);
+        }
+        return;
+    }
+    if (!rh->uv_handle) {
+        rh->uv_handle = malloc(sizeof(uv_poll_t));
+        if (!rh->uv_handle) return;
+        uv_poll_init(ts->uv_loop, rh->uv_handle, rh->fd);
+        rh->uv_handle->data = rh;
+    }
+    uv_poll_start(rh->uv_handle, events, qn_poll_rw_cb);
+}
