# qjsx.patch - Patches to QuickJS CLI for QJSXPATH module resolution
#
# Target file: quickjs/qjs.c
# Output: bin/<platform>/obj/qjsx.c -> compiled to qjsx binary
# Applied by: Makefile rule for $(BIN_DIR)/obj/qjsx.c
#
# Features added:
#
#   1. QJSXPATH module resolution
#      Custom module loader that supports:
#      - QJSXPATH environment variable for bare import resolution
#      - .js extension and /index.js fallbacks (bundler mode)
#      - Strict ESM resolution (node mode via QJSX_MODULE_RESOLUTION=node)
#
#   2. Exit handler support
#      Calls qjsx_call_exit_handler() for process.on('exit') callbacks
#      and returns proper exit code from process.exitCode.
#
#   3. Branding changes
#      - Program name changed from "qjs" to "qjsx"
#      - Help text updated to document QJSXPATH usage
#
--- quickjs/qjs.c	2025-10-08 10:58:22.940197863 +0000
+++ bin/linux/obj/qjsx.c	2026-01-17 22:06:16.144952052 +0000
@@ -42,10 +42,40 @@
 
 #include "cutils.h"
 #include "quickjs-libc.h"
+#include "module_resolution/module-resolution.h"
+#include "exit-handler.h"
 
 extern const uint8_t qjsc_repl[];
 extern const uint32_t qjsc_repl_size;
 
+static JSModuleDef *qjsx_loader(JSContext *ctx, const char *name, void *opaque, JSValueConst attributes) {
+    // Note: 'name' is already normalized by qjsx_module_normalizer
+    // (colon-to-slash done, relative paths resolved, .js/.index.js stripped in bundler mode)
+
+    // Bare imports: try QJSXPATH resolution
+    if (name[0] != '.' && name[0] != '/') {
+        char *path = resolve_qjsxpath(ctx, name);
+        if (path) {
+            JSModuleDef *mod = js_module_loader(ctx, path, opaque, attributes);
+            js_free(ctx, path);
+            return mod;
+        }
+    }
+
+    // File paths: try with .js extension and /index.js (skip in node mode)
+    if (!is_node_resolution()) {
+        char *resolved_path = resolve_with_index(ctx, name);
+        if (resolved_path) {
+            JSModuleDef *mod = js_module_loader(ctx, resolved_path, opaque, attributes);
+            js_free(ctx, resolved_path);
+            return mod;
+        }
+    }
+
+    // Fallback: try exact name
+    return js_module_loader(ctx, name, opaque, attributes);
+}
+
 static int eval_buf(JSContext *ctx, const void *buf, int buf_len,
                     const char *filename, int eval_flags)
 {
@@ -283,11 +313,11 @@
     return v;
 }
 
-#define PROG_NAME "qjs"
+#define PROG_NAME "qjsx"
 
 void help(void)
 {
-    printf("QuickJS version " CONFIG_VERSION "\n"
+    printf("QJSX (QuickJS with QJSXPATH) version " CONFIG_VERSION "\n"
            "usage: " PROG_NAME " [options] [file [args]]\n"
            "-h  --help         list options\n"
            "-e  --eval EXPR    evaluate EXPR\n"
@@ -303,7 +333,11 @@
            "    --no-unhandled-rejection  ignore unhandled promise rejections\n"
            "-s                    strip all the debug info\n"
            "    --strip-source    strip the source code\n"
-           "-q  --quit         just instantiate the interpreter and quit\n");
+           "-q  --quit         just instantiate the interpreter and quit\n"
+           "\n"
+           "QJSXPATH module resolution:\n"
+           "  Set QJSXPATH environment variable for Node.js-style module resolution.\n"
+           "  Example: QJSXPATH=./my_modules:./lib qjsx script.js\n");
     exit(1);
 }
 
@@ -465,7 +499,7 @@
     }
 
     /* loader for ES6 modules */
-    JS_SetModuleLoaderFunc2(rt, NULL, js_module_loader, js_module_check_attributes, NULL);
+    JS_SetModuleLoaderFunc2(rt, qjsx_module_normalizer, qjsx_loader, js_module_check_attributes, NULL);
 
     if (dump_unhandled_promise_rejection) {
         JS_SetHostPromiseRejectionTracker(rt, js_std_promise_rejection_tracker,
@@ -508,6 +542,7 @@
         }
         js_std_loop(ctx);
     }
+    int exit_code = qjsx_call_exit_handler(ctx);
 
     if (dump_memory) {
         JSMemoryUsage stats;
@@ -542,7 +577,7 @@
                best[1] + best[2] + best[3] + best[4],
                best[1], best[2], best[3], best[4]);
     }
-    return 0;
+    return exit_code;
  fail:
     js_std_free_handlers(rt);
     JS_FreeContext(ctx);
