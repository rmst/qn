+static QJSXModuleResolverContext qjsx_resolver_ctx = { NULL };
+
+static JSModuleDef *qjsx_loader(JSContext *ctx, const char *name, void *opaque, JSValueConst attributes) {
+    // Note: 'name' is already normalized by qjsx_module_normalizer
+    // (colon-to-slash done, relative paths resolved, .js/.index.js stripped in bundler mode)
+
+    // Bare imports: try NODE_PATH resolution
+    if (name[0] != '.' && name[0] != '/') {
+        char *path = resolve_node_path(ctx, name);
+        if (path) {
+            JSModuleDef *mod = js_module_loader(ctx, path, opaque, attributes);
+            js_free(ctx, path);
+            return mod;
+        }
+    }
+
+    // File paths: try with .js extension and /index.js (skip in node mode)
+    if (!is_node_resolution()) {
+        char *resolved_path = resolve_with_index(ctx, name);
+        if (resolved_path) {
+            JSModuleDef *mod = js_module_loader(ctx, resolved_path, opaque, attributes);
+            js_free(ctx, resolved_path);
+            return mod;
+        }
+    }
+
+    // Fallback: try exact name
+    return js_module_loader(ctx, name, opaque, attributes);
+}
