# quickjs.patch - Patches to QuickJS core engine
#
# Target files: quickjs/quickjs.c, quickjs/quickjs.h
# Applied by: make quickjs-deps (copies quickjs/ to bin/<platform>/quickjs/ then patches)
#
# Features added:
#
#   1. JS_GetClosureVars(ctx, func) - API to inspect closure variables
#      Used by qn:introspect for function serialization.
#      Returns JS object { varName: { value, type }, ... } where type is
#      one of: "local", "arg", "ref", "global", "module".
#
#   2. Import error source locations
#      Import resolution errors now include the importing file and line number.
#      Example: "Could not find export 'foo' in module 'bar.js' (imported at main.js:5)"
#      - Adds line_num field to JSImportEntry struct
#      - Captures line number during import statement parsing
#      - Enhanced error messages in js_link_module()
#
#   3. Module loading error context
#      When a module fails to load, the error message includes which file
#      tried to import it.
#      Example: "could not load module filename 'foo.js' (imported from 'main.js')"
#
--- quickjs/quickjs.c	2026-02-21 11:28:24.635574389 +0000
+++ bin/linux/quickjs/quickjs.c	2026-02-21 15:33:15.900924578 +0000
@@ -809,6 +809,7 @@
     BOOL is_star; /* import_name = '*' is a valid import name, so need a flag */
     JSAtom import_name;
     int req_module_idx; /* in req_module_entries */
+    int line_num; /* line number of the import statement */
 } JSImportEntry;

 typedef enum {
@@ -15731,6 +15732,71 @@
     return JS_UNDEFINED;
 }

+/* Get closure variables as a JS object { varName: { value, type }, ... }
+   type is one of: "local", "arg", "ref", "global", "module" */
+JSValue JS_GetClosureVars(JSContext *ctx, JSValueConst func_val)
+{
+    JSObject *p;
+    JSFunctionBytecode *b;
+    JSValue obj;
+    int i;
+
+    if (JS_VALUE_GET_TAG(func_val) != JS_TAG_OBJECT)
+        return JS_UNDEFINED;
+    p = JS_VALUE_GET_OBJ(func_val);
+    if (!js_class_has_bytecode(p->class_id))
+        return JS_UNDEFINED;
+
+    b = p->u.func.function_bytecode;
+    if (!b || b->closure_var_count == 0)
+        return JS_NewObject(ctx);
+
+    obj = JS_NewObject(ctx);
+    if (JS_IsException(obj))
+        return obj;
+
+    for (i = 0; i < b->closure_var_count; i++) {
+        JSClosureVar *cv = &b->closure_var[i];
+        JSVarRef *var_ref = p->u.func.var_refs[i];
+        JSValue entry, val;
+        const char *type_str;
+
+        if (var_ref) {
+            val = JS_DupValue(ctx, *var_ref->pvalue);
+        } else {
+            val = JS_UNDEFINED;
+        }
+
+        switch (cv->closure_type) {
+        case JS_CLOSURE_LOCAL:   type_str = "local"; break;
+        case JS_CLOSURE_ARG:     type_str = "arg"; break;
+        case JS_CLOSURE_REF:     type_str = "ref"; break;
+        case JS_CLOSURE_GLOBAL_REF:
+        case JS_CLOSURE_GLOBAL_DECL:
+        case JS_CLOSURE_GLOBAL:  type_str = "global"; break;
+        case JS_CLOSURE_MODULE_DECL:
+        case JS_CLOSURE_MODULE_IMPORT:
+                                 type_str = "module"; break;
+        default:                 type_str = "unknown"; break;
+        }
+
+        entry = JS_NewObject(ctx);
+        if (JS_IsException(entry)) {
+            JS_FreeValue(ctx, val);
+            JS_FreeValue(ctx, obj);
+            return JS_EXCEPTION;
+        }
+        JS_SetPropertyStr(ctx, entry, "value", val);
+        JS_SetPropertyStr(ctx, entry, "type", JS_NewString(ctx, type_str));
+
+        if (JS_SetProperty(ctx, obj, cv->var_name, entry) < 0) {
+            JS_FreeValue(ctx, obj);
+            return JS_EXCEPTION;
+        }
+    }
+    return obj;
+}
+
 static int js_arguments_define_own_property(JSContext *ctx,
                                             JSValueConst this_obj,
                                             JSAtom prop, JSValueConst val,
@@ -29946,8 +30012,25 @@
         m1 = js_host_resolve_imported_module_atom(ctx, m->module_name,
                                                   rme->module_name,
                                                   rme->attributes);
-        if (!m1)
+        if (!m1) {
+            /* Enhance the error message with the importing module name */
+            if (JS_HasException(ctx)) {
+                JSValue exc = JS_GetException(ctx);
+                JSValue msg_val = JS_GetPropertyStr(ctx, exc, "message");
+                const char *msg = JS_ToCString(ctx, msg_val);
+                char buf[ATOM_GET_STR_BUF_SIZE];
+                const char *import_str = JS_AtomGetStr(ctx, buf, sizeof(buf), m->module_name);
+                if (msg) {
+                    JS_ThrowReferenceError(ctx, "%s (imported from '%s')", msg, import_str);
+                } else {
+                    JS_ThrowReferenceError(ctx, "could not load module (imported from '%s')", import_str);
+                }
+                JS_FreeCString(ctx, msg);
+                JS_FreeValue(ctx, msg_val);
+                JS_FreeValue(ctx, exc);
+            }
             return -1;
+        }
         rme->module = m1;
         /* already done in js_host_resolve_imported_module() except if
            the module was loaded with JS_EvalBinary() */
@@ -30145,7 +30228,29 @@
                 ret = js_resolve_export(ctx, &res_m,
                                         &res_me, m1, mi->import_name);
                 if (ret != JS_RESOLVE_RES_FOUND) {
-                    js_resolve_export_throw_error(ctx, ret, m1, mi->import_name);
+                    char buf1[ATOM_GET_STR_BUF_SIZE];
+                    char buf2[ATOM_GET_STR_BUF_SIZE];
+                    char buf3[ATOM_GET_STR_BUF_SIZE];
+                    const char *export_str = JS_AtomGetStr(ctx, buf1, sizeof(buf1), mi->import_name);
+                    const char *target_str = JS_AtomGetStr(ctx, buf2, sizeof(buf2), m1->module_name);
+                    const char *import_str = JS_AtomGetStr(ctx, buf3, sizeof(buf3), m->module_name);
+                    switch (ret) {
+                    case JS_RESOLVE_RES_EXCEPTION:
+                        break;
+                    default:
+                    case JS_RESOLVE_RES_NOT_FOUND:
+                        JS_ThrowSyntaxError(ctx, "Could not find export '%s' in module '%s' (imported at %s:%d)",
+                                            export_str, target_str, import_str, mi->line_num);
+                        break;
+                    case JS_RESOLVE_RES_CIRCULAR:
+                        JS_ThrowSyntaxError(ctx, "circular reference when looking for export '%s' in module '%s' (imported at %s:%d)",
+                                            export_str, target_str, import_str, mi->line_num);
+                        break;
+                    case JS_RESOLVE_RES_AMBIGUOUS:
+                        JS_ThrowSyntaxError(ctx, "export '%s' in module '%s' is ambiguous (imported at %s:%d)",
+                                            export_str, target_str, import_str, mi->line_num);
+                        break;
+                    }
                     goto fail;
                 }
                 if (res_me->local_name == JS_ATOM__star_) {
@@ -31297,6 +31402,11 @@
     mi->import_name = JS_DupAtom(ctx, import_name);
     mi->var_idx = var_idx;
     mi->is_star = is_star;
+    {
+        int col_num;
+        mi->line_num = get_line_col(&col_num, s->buf_start,
+                                    s->token.ptr - s->buf_start) + 1;
+    }
     return 0;
 }

--- quickjs/quickjs.h	2026-02-21 11:28:24.637597145 +0000
